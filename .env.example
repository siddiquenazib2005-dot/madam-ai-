# MADAM AI — Environment Variables
# ══════════════════════════════

# Grok API (xAI) — get from: https://console.x.ai
GROK_API_KEY=your_grok_api_key_here

# Weather API — get free key from: https://openweathermap.org
WEATHER_API_KEY=your_openweather_key_here

# News API — get free key from: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Serper (Google Search) — get free key from: https://serper.dev
SERPER_API_KEY=your_serper_key_here

# Server port
PORT=3000
